{
  "version": 2,
  "functions": {
    "api/nba.js": { "memory": 256, "maxDuration": 10 },
    "api/mlb.js": { "memory": 256, "maxDuration": 10 },
    "api/f1.js":  { "memory": 256, "maxDuration": 10 }
  },
  "rewrites": [
    { "source": "/api/nba/:path*", "destination": "/api/nba" },
    { "source": "/api/mlb/:path*", "destination": "/api/mlb" },
    { "source": "/api/f1/:path*",  "destination": "/api/f1"  }
  ],
  "headers": [
    {
      "source": "/api/(.*)",
      "headers": [
        { "key": "Access-Control-Allow-Origin",  "value": "*" },
        { "key": "Access-Control-Allow-Methods", "value": "GET, OPTIONS" }
      ]
    }
  ]
}
