{
  "version": 2,
  "rewrites": [
    { "source": "/api/nba/:path*", "destination": "/api/nba?path=:path*" },
    { "source": "/api/mlb/:path*", "destination": "/api/mlb?path=:path*" },
    { "source": "/api/f1/:path*",  "destination": "/api/f1?path=:path*"  }
  ],
  "headers": [
    {
      "source": "/api/(.*)",
      "headers": [
        { "key": "Access-Control-Allow-Origin",  "value": "*" },
        { "key": "Access-Control-Allow-Methods", "value": "GET, OPTIONS" }
      ]
    }
  ]
}
